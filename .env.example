# Telegram Bot API token from @BotFather
BOT_TOKEN=

# Secret token for webhook verification (optional but recommended)
TELEGRAM_WEBHOOK_SECRET=

# Public URL of the deployed app (for setWebhook)
WEBHOOK_URL=https://your-domain.vercel.app/api/webhook

# Bearer token to protect /api/telegram/set-webhook (optional)
SETUP_SECRET=

# OpenRouter (recommended) — model openai/gpt-4o-mini
OPENROUTER_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Or direct OpenAI
# OPENAI_API_KEY=

# Google Custom Search JSON API
# https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
