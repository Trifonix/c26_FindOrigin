# Telegram Bot API token from @BotFather
BOT_TOKEN=

# Secret token for webhook verification (optional but recommended)
TELEGRAM_WEBHOOK_SECRET=

# Public URL of the deployed app (for setWebhook)
WEBHOOK_URL=https://your-domain.vercel.app/api/webhook

# Telegram Mini App URL (auto-derived from WEBHOOK_URL if omitted)
WEBAPP_URL=https://your-domain.vercel.app/mini-app

# Local dev only: skip initData validation in Mini App API
# SKIP_TMA_AUTH=true

# Bearer token to protect /api/telegram/set-webhook (optional)
SETUP_SECRET=

# OpenRouter — бесплатно через роутер openrouter/free
OPENROUTER_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openrouter/free

# Альтернативы (проверяйте актуальность на openrouter.ai/models?q=free):
# AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
# AI_MODEL=openai/gpt-4o-mini  → платная, нужны кредиты

# Or direct OpenAI
# OPENAI_API_KEY=

# Web search — Serper (recommended, Google results via API)
# https://serper.dev — free tier 2500 queries
SERPER_API_KEY=

# Legacy: Google Custom Search (no longer supports "search entire web" for new accounts)
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=
