# Telegram Bot API token from @BotFather
BOT_TOKEN=

# Secret token for webhook verification (optional but recommended)
TELEGRAM_WEBHOOK_SECRET=

# Public URL of the deployed app (for setWebhook)
WEBHOOK_URL=

# Bearer token to protect /api/telegram/set-webhook (optional)
SETUP_SECRET=

# OpenAI API key for entity extraction and source comparison
OPENAI_API_KEY=

# Web search API (for stage 5+)
TAVILY_API_KEY=
